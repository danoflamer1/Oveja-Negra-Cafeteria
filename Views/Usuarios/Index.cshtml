@model IEnumerable<OvejaNegra.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}
<style>
    .user-id {
        font-weight: 700;
        color: #111827;
    }
    .password-mask {
        font-weight: 700;
        letter-spacing: 1px;
    }
</style>

<div class="container mt-4">


    <div class="page-header">

        <div>

            <div class="title">
                Gestión de Usuarios
            </div>

            <div class="subtitle">
                Administra el personal de la cafetería
            </div>

        </div>

        <a asp-action="Create"
           class="btn-add">

            <i class="bi bi-person-plus"></i>
            Añadir Usuario

        </a>

    </div>

    <div class="table-card">

        <table class="custom-table">

            <thead>

                <tr>

                    <th>ID</th>

                    <th>Nombre</th>

                    <th>Apellido</th>

                    <th>Username</th>

                    <th>Password</th>

                    <th>Rol</th>

                    <th>Acciones</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="user-id">
                            @item.Id
                        </td>

                        <td>
                            @item.Nombre
                        </td>

                        <td>
                            @item.Apellido
                        </td>

                        <td>
                            @item.username
                        </td>

                        <td class="password-mask">
                            ********
                        </td>

                        <td>

                            @{
                                string claseRol = "";

                                if (item.Rol.ToString() == "Administrador")
                                    claseRol = "admin";

                                else if (item.Rol.ToString() == "Mesero")
                                    claseRol = "mesero";

                                else if (item.Rol.ToString() == "Cocinero")
                                    claseRol = "cocinero";

                                else if (item.Rol.ToString() == "Cajero")
                                    claseRol = "cajero";
                            }

                            <span class="badge-role @claseRol">
                                @item.Rol
                            </span>

                        </td>


                        <td>

                            <div class="acciones">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="ver">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="editar">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                               

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>