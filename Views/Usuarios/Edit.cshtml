@model OvejaNegra.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}
<div class="form-card">
    <div class="header">
        <div class="title">Editar Usuario</div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success mx-3 mt-3">@TempData["Mensaje"]</div>
    }
    @if (TempData["ErrorReset"] != null)
    {
        <div class="alert alert-danger mx-3 mt-3">@TempData["ErrorReset"]</div>
    }

    <form asp-action="Edit">
        <div class="body-custom">
            <input type="hidden" asp-for="Id" />
            <div class="grid">
                <div>
                    <label>Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>
                <div>
                    <label>Apellido</label>
                    <input asp-for="Apellido" class="form-control" />
                </div>
                <div class="full">
                    <label>Username</label>
                    <input asp-for="username" class="form-control" />
                </div>
                <div>
                    <label>Rol</label>
                    <select asp-for="Rol" class="form-select">
                        <option value="1">Administrador</option>
                        <option value="2">Cajero</option>
                        <option value="3">Mesero</option>
                        <option value="4">Cocinero</option>
                    </select>
                </div>
                <div>
                    <label>Estado</label>
                    <select class="form-select">
                        <option>Activo</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="footer">
            <a asp-action="Index" class="btn-cancel">Cancelar</a>
            <button type="submit" class="btn-save">Guardar Cambios</button>
        </div>
    </form>
    <div class="body-custom" style="border-top: 1px solid #f1ede5; padding-top: 20px;">
        <button type="button" class="btn-save" style="background:#6b7280; width:100%;"
                onclick="document.getElementById('reset-section').style.display =
                         document.getElementById('reset-section').style.display === 'none' ? 'block' : 'none'">
            <i></i> Modificar Contraseña
        </button>

        <div id="reset-section" style="display:none; margin-top:16px;">
            <form asp-action="ResetearPassword" asp-controller="Usuarios" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="grid">
                    <div class="full">
                        <label>Nueva Contraseña</label>
                        <input type="password" name="nuevaPassword" id="nuevaPassword"
                               class="form-control" placeholder="Mínimo 8 caracteres"
                               oninput="verificarLongitud(this.value)" />
                        <small id="error-longitud" style="color:#dc2626; display:none; margin-top:4px;">
                            La contraseña debe tener mínimo 8 caracteres
                        </small>
                    </div>
                    <div class="full">
                        <label>Confirmar Contraseña</label>
                        <input type="password" id="confirmarPassword"
                               class="form-control" placeholder="Repetir contraseña" />
                        <small id="error-pass" style="color:#dc2626; display:none; margin-top:4px;">
                            Las contraseñas no coinciden
                        </small>
                    </div>
                </div>
                <div style="margin-top:16px; display:flex; justify-content:flex-end;">
                    <button type="submit" class="btn-save" onclick="return validarPassword()">
                        <i></i> Guardar Nueva Contraseña
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
        function verificarLongitud(valor) {
        const error = document.getElementById('error-longitud');
        if (valor.length > 0 && valor.length < 8) {
            error.style.display = 'block';
        } else {
            error.style.display = 'none';
        }
    }
    function validarPassword() {
        const nueva = document.getElementById('nuevaPassword').value;
        const confirmar = document.getElementById('confirmarPassword').value;
        const error = document.getElementById('error-pass');

        if (nueva !== confirmar) {
            error.style.display = 'block';
            return false;
        }
        error.style.display = 'none';
        return true;
    }

    @if (TempData["ErrorReset"] != null)
    {
            <text>document.getElementById('reset-section').style.display = 'block';</text>
    }
        function validarPassword() {
        const nueva = document.getElementById('nuevaPassword').value;
        const confirmar = document.getElementById('confirmarPassword').value;
        const errorCoincide = document.getElementById('error-pass');
        const errorLongitud = document.getElementById('error-longitud');

        let valido = true;

        if (nueva.length < 8) {
            errorLongitud.style.display = 'block';
            valido = false;
        } else {
            errorLongitud.style.display = 'none';
        }

        if (nueva !== confirmar) {
            errorCoincide.style.display = 'block';
            valido = false;
        } else {
            errorCoincide.style.display = 'none';
        }

        return valido;
    }
</script>
