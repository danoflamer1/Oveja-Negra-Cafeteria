@model OvejaNegra.Models.Producto
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="form-card">
    <div class="header">
        <div class="title">Eliminar Producto</div>
        <a asp-action="Index" style="font-size:28px;color:#6b7280;text-decoration:none;">×</a>
    </div>

    <div class="body-custom">
        <div style="background:#fee2e2; border-radius:16px; padding:16px 20px; margin-bottom:24px; color:#dc2626; font-weight:500;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            ¿Estás seguro de que deseas eliminar este producto? Esta acción no se puede deshacer.
        </div>

        <div class="grid">
            <div>
                <label>Nombre</label>
                <div class="form-control" style="height:auto; padding:12px 16px; background:#faf8f3; color:#111827;">
                    @Model.Nombre
                </div>
            </div>
            <div>
                <label>Precio</label>
                <div class="form-control" style="height:auto; padding:12px 16px; background:#faf8f3; color:#7c5a27; font-weight:700;">
                    Bs @Model.Precio.ToString("0.00")
                </div>
            </div>
            <div>
                <label>Categoría</label>
                <div class="form-control" style="height:auto; padding:12px 16px; background:#faf8f3;">
                    <span class="categoria-badge">@Model.Categoria?.Nombre</span>
                </div>
            </div>
            <div>
                <label>Disponible</label>
                <div class="form-control" style="height:auto; padding:12px 16px; background:#faf8f3;">
                    @if (Model.Disponible)
                    {
                        <span class="estado disponible">Disponible</span>
                    }
                    else
                    {
                        <span class="estado nodisponible">No disponible</span>
                    }
                </div>
            </div>
            <div class="full">
                <label>Descripción</label>
                <div class="form-control" style="height:auto; padding:12px 16px; background:#faf8f3; color:#6b7280;">
                    @Model.Descripcion
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Imagen))
            {
                <div class="full">
                    <label>Imagen</label>
                    <img src="@Model.Imagen" alt="Imagen del producto"
                         style="width:80px; height:80px; border-radius:14px; object-fit:cover;" />
                </div>
            }
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="footer">
            <a asp-action="Index" class="btn btn-cancel">Cancelar</a>
            <button type="submit" class="btn-save"
                    style="background:#dc2626;">
                <i class="bi bi-trash"></i> Confirmar Eliminación
            </button>
        </div>
    </form>
</div>