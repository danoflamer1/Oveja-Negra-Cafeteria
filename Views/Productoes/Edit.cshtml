@model OvejaNegra.Models.Producto
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="form-card">
    <div class="header">
        <div class="title">Editar Producto</div>
        <a asp-action="Index" style="font-size:28px;color:#6b7280;text-decoration:none;">×</a>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data">
        <div class="body-custom">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="grid">
                <div>
                    <label>Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div>
                    <label>Precio</label>
                    <input asp-for="Precio" class="form-control" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>
                <div class="full">
                    <label>Descripción</label>
                    <input asp-for="Descripcion" class="form-control" />
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>
                <div class="full">
                    <label>Categoría</label>
                    <select asp-for="CategoriaId" class="form-select"
                            asp-items="ViewBag.CategoriaId"></select>
                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                </div>
                <div class="full">
                    <label>Imagen</label>
                    <input asp-for="ImagenFile" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImagenFile" class="text-danger"></span>
                    @if (!string.IsNullOrEmpty(Model.Imagen))
                    {
                        <img src="@Model.Imagen" alt="Imagen actual"
                             style="margin-top:10px; width:80px; height:80px;
                    border-radius:14px; object-fit:cover;" />
                        <small style="color:#6b7280; display:block; margin-top:4px;">
                            Imagen actual — sube una nueva para reemplazarla
                        </small>
                    }
                </div>
                <div>
                    <label>Disponible</label>
                    <div style="display:flex; align-items:center; gap:10px; margin-top:8px;">
                        <input asp-for="Disponible" class="form-check-input"
                               style="width:20px; height:20px; cursor:pointer;" />
                        <span style="color:#6b7280; font-size:14px;">
                            Marcar como disponible
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer">
            <a asp-action="Index" class="btn btn-cancel">Cancelar</a>
            <button type="submit" class="btn-save">Guardar Cambios</button>
        </div>
    </form>
</div>