@model IEnumerable<OvejaNegra.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}
<style>
    .product-img {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        object-fit: cover;
    }

    .product-name {
        font-weight: 600;
        color: #111827;
    }

    .price {
        font-weight: 700;
        color: #7c5a27;
    }

    .descripcion {
        max-width: 280px;
        color: #6b7280;
    }
</style>
<div class="container mt-4">

    <!-- HEADER -->

    <div class="page-header">

        <div>

            <div class="title">
                Gestión de Productos
            </div>

            <div class="subtitle">
                Administra el menú de la cafetería
            </div>

        </div>

        <a asp-action="Create"
           class="btn-add">

            <i class="bi bi-plus-lg"></i>
            Añadir Producto

        </a>

    </div>

    <!-- TABLA -->

    <div class="table-card">

        <table class="custom-table">

            <thead>

                <tr>

                    <th>Imagen</th>

                    <th>Nombre</th>

                    <th>Precio</th>

                    <th>Estado</th>

                    <th>Descripción</th>

                    <th>Categoría</th>

                    <th>Acciones</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- IMAGEN -->

                        <td>
                            @if (!string.IsNullOrEmpty(item.Imagen))
                            {
                                <img src="@item.Imagen" class="product-img" />
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/60" class="product-img" />
                            }
                        </td>

                        <!-- NOMBRE -->

                        <td class="product-name">
                            @item.Nombre
                        </td>

                        <!-- PRECIO -->

                        <td class="price">
                            @item.Precio Bs.
                        </td>

                        <!-- ESTADO -->

                        <td>

                            @if (item.Disponible)
                            {
                                <span class="estado disponible">
                                    Disponible
                                </span>
                            }
                            else
                            {
                                <span class="estado nodisponible">
                                    No Disponible
                                </span>
                            }

                        </td>

                        <!-- DESCRIPCION -->

                        <td class="descripcion">
                            @item.Descripcion
                        </td>

                        <!-- CATEGORIA -->

                        <td>

                            <span class="categoria-badge">
                                @item.Categoria?.Nombre
                            </span>

                        </td>

                        <!-- ACCIONES -->

                        <td>

                            <div class="acciones">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="editar">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="eliminar">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>